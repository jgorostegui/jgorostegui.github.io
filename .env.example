# homepage-v7 environment variables
# Copy to .env to activate; never commit .env

# ---- Build-time feature flags ----
# Must be set BEFORE `bun run build`. Gate build steps and their
# corresponding runtime UI (search button, OG meta tags).

# Enables Pagefind full-text search (build step + UI).
# 'true' = postbuild runs pagefind --site dist, header shows search button.
ENABLE_SEARCH=true

# Enables dynamic Open Graph image generation for blog posts (Satori + Sharp).
# 'true' = /og/<slug>.png endpoint emits per-post images at build time.
ENABLE_OG_IMAGES=true

# ---- Runtime config ----

# Cloudflare Web Analytics site token (JS Beacon mode).
# Get from Cloudflare dashboard > Web Analytics > site > JS snippet.
# Empty = analytics disabled. Cookie-free, no consent banner required.
PUBLIC_CLOUDFLARE_ANALYTICS_TOKEN=
