{
  "name": "astro-erudite",
  "type": "module",
  "version": "1.6.3",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && astro build && bun scripts/postbuild.ts",
    "preview": "astro preview",
    "astro": "astro",
    "prettier": "prettier --write **/*.{ts,tsx,css,astro} --ignore-path .gitignore"
  },
  "dependencies": {
    "@astrojs/check": "0.9.7",
    "@astrojs/markdown-remark": "7.0.0",
    "@astrojs/mdx": "5.0.0",
    "@astrojs/react": "5.0.0",
    "@astrojs/rss": "4.0.17",
    "@astrojs/sitemap": "3.7.1",
    "@expressive-code/plugin-collapsible-sections": "^0.40.2",
    "@expressive-code/plugin-line-numbers": "^0.40.2",
    "@iconify-json/lucide": "^1.2.26",
    "@resvg/resvg-js": "^2.6.2",
    "@shikijs/rehype": "^3.4.0",
    "@tailwindcss/vite": "^4.2.2",
    "@tsparticles/engine": "^3.9.1",
    "@tsparticles/react": "^3.0.0",
    "@tsparticles/slim": "^3.9.1",
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "astro": "6.0.2",
    "astro-icon": "^1.1.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.469.0",
    "radix-ui": "^1.3.4",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "rehype-expressive-code": "^0.40.2",
    "rehype-external-links": "^3.0.0",
    "rehype-katex": "^7.0.1",
    "remark-emoji": "^5.0.1",
    "remark-math": "^6.0.0",
    "satori": "^0.26.0",
    "tailwind-merge": "^3.3.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.8.3"
  },
  "devDependencies": {
    "@fontsource/geist": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@types/bun": "^1.3.11",
    "pagefind": "^1.5.0",
    "playwright": "^1.59.1",
    "prettier": "^3.5.1",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-astro-organize-imports": "^0.4.11",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "wawoff2": "^2.0.1"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "plugins": [
      "prettier-plugin-astro",
      "prettier-plugin-tailwindcss",
      "prettier-plugin-astro-organize-imports"
    ],
    "overrides": [
      {
        "files": "*.astro",
        "options": {
          "parser": "astro"
        }
      }
    ]
  }
}
