---
import BlogCard from '@/components/blog-card.astro'
import Link from '@/components/link.astro'
import PageHead from '@/components/page-head.astro'
import { buttonVariants } from '@/components/ui/button'
import { SITE } from '@/consts'
import Layout from '@/layouts/layout.astro'
import { getRecentPosts } from '@/lib/data-utils'
import StarField from '@/components/StarField'

const blog = await getRecentPosts(SITE.featuredPostCount)
---

<Layout class="max-w-3xl">
  <PageHead slot="head" title="Home" />

  <section slot="hero" class="hero-shell">
    <StarField client:only="react" />

    <div class="hero-vignette" aria-hidden="true"></div>

    <div id="meteors" class="hero-meteors" aria-hidden="true">
      <div class="meteor-lane" style="transform: rotate(45deg)"></div>
      <div class="meteor-lane" style="transform: rotate(135deg)"></div>
      <div class="meteor-lane" style="transform: rotate(225deg)"></div>
      <div class="meteor-lane" style="transform: rotate(315deg)"></div>
    </div>

    <div class="hero-bottom-line" aria-hidden="true"></div>

    <div class="hero-frame">
      <div class="hero-grid">
        <div class="hero-copy">
          <div class="hero-fade hero-delay-1 hero-command">$ whoami</div>

          <h1 class="hero-fade hero-delay-2 hero-name">
            Josu Gorostegui<span class="cursor-blink" aria-hidden="true">_</span>
          </h1>

          <p class="hero-fade hero-delay-3 hero-lede">
            Software engineer. Generalist. Machine learning.
          </p>

          <nav class="hero-fade hero-delay-5 hero-social">
            <a href="https://github.com/jgorostegui" target="_blank">github</a>
            <span>/</span>
            <a href="https://twitter.com/josu_goros" target="_blank">twitter</a>
            <span>/</span>
            <a href="https://linkedin.com/in/josugorostegui" target="_blank"
              >linkedin</a
            >
            <span>/</span>
            <a href="https://jgorostegui.medium.com" target="_blank">medium</a>
          </nav>
        </div>
      </div>
    </div>
  </section>

  <section class="hero-fade hero-delay-6 flex flex-col gap-y-4">
    <h2 class="text-lg font-mono font-medium tracking-tight">Latest posts</h2>
    <ul class="flex flex-col gap-y-4">
      {
        blog.map((post) => (
          <li>
            <BlogCard entry={post} />
          </li>
        ))
      }
    </ul>
    <div class="flex justify-center">
      <Link href="/blog" class={buttonVariants({ variant: 'ghost' }) + ' group'}>
        See all posts <span class="ml-1.5 transition-transform group-hover:translate-x-1"
          >&rarr;</span
        >
      </Link>
    </div>
  </section>
</Layout>

<style>
  .hero-shell {
    position: relative;
    width: 100%;
    min-height: 20rem;
    height: min(30rem, 46vh);
    max-height: 30rem;
    overflow: hidden;
    background: var(--hero-bg, #000);
  }

  :root { --hero-bg: var(--background, #fff); --hero-fg: var(--foreground, #111); --hero-muted: rgba(0,0,0,0.52); --hero-dim: rgba(0,0,0,0.38); --hero-faint: rgba(0,0,0,0.18); --hero-vig-tint: var(--background, #fff); }
  :root[data-theme='dark'] { --hero-bg: #000; --hero-fg: #fff; --hero-muted: rgba(255,255,255,0.52); --hero-dim: rgba(255,255,255,0.4); --hero-faint: rgba(255,255,255,0.18); --hero-vig-tint: var(--background, #0d0d0d); }
  :root[data-theme='cyberpunk'] { --hero-bg: #06060e; --hero-fg: #e0e4ff; --hero-muted: rgba(224,228,255,0.52); --hero-dim: rgba(0,240,255,0.5); --hero-faint: rgba(0,240,255,0.18); --hero-vig-tint: #0a0a14; }

  /* Stars handled by tsParticles StarField component */

  .hero-vignette {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(180deg, transparent 0%, transparent 60%, var(--hero-vig-tint) 100%);
    z-index: 2;
  }

  :root[data-theme='dark'] .hero-vignette {
    background:
      radial-gradient(ellipse 36% 22% at 52% 20%, rgba(255, 255, 255, 0.045), transparent 72%),
      linear-gradient(180deg, rgba(3, 4, 6, 0.14) 0%, transparent 24%, transparent 60%, var(--background, #0d0d0d) 100%),
      radial-gradient(circle at 50% 14%, transparent 20%, rgba(3, 4, 6, 0.18) 100%);
  }

  .hero-bottom-line {
    display: none;
  }

  .hero-frame {
    position: absolute;
    inset: 0;
    z-index: 4;
    width: min(100%, 48rem);
    margin: 0 auto;
    height: 100%;
    padding: 0 1rem;
    display: grid;
    align-items: center;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    align-items: start;
  }

  .hero-copy {
    display: grid;
    gap: 0.82rem;
    align-content: center;
    min-height: 14rem;
  }

  .hero-eyebrow {
    color: rgba(255, 255, 255, 0.42);
    font-size: 0.78rem;
    line-height: 1;
    letter-spacing: -0.01em;
  }

  .hero-command {
    display: inline-flex;
    width: fit-content;
    align-items: center;
    color: var(--hero-muted);
    font-family: var(--font-mono, 'JetBrains Mono', ui-monospace, monospace);
    font-size: 0.9rem;
    line-height: 1.2;
    font-weight: 500;
  }

  .hero-name {
    margin: 0;
    color: var(--hero-fg);
    font-size: clamp(2.2rem, 4.5vw, 3.2rem);
    line-height: 1;
    letter-spacing: -0.04em;
    font-weight: 620;
    white-space: nowrap;
  }

  .cursor-blink {
    display: inline;
    color: var(--hero-dim);
    animation: cursorPulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }

  .hero-lede {
    max-width: 35rem;
    color: var(--hero-muted);
    font-size: clamp(1rem, 1.8vw, 1.05rem);
    line-height: 1.68;
    letter-spacing: -0.01em;
  }

  .hero-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    color: var(--hero-muted);
    font-size: 0.73rem;
    line-height: 1;
    font-weight: 500;
    text-transform: lowercase;
  }

  .hero-legend span::before {
    content: '';
    display: inline-block;
    width: 0.38rem;
    height: 0.38rem;
    margin-right: 0.45rem;
    border-radius: 999px;
    vertical-align: middle;
    transform: translateY(-0.02rem);
  }

  .hero-legend span:nth-child(1)::before { background: var(--hero-fg); opacity: 0.94; }
  .hero-legend span:nth-child(2)::before { background: var(--hero-fg); opacity: 0.58; }
  .hero-legend span:nth-child(3)::before { background: var(--hero-fg); opacity: 0.28; }

  .hero-social {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    color: var(--hero-dim);
    font-size: 0.78rem;
    line-height: 1;
    font-weight: 500;
    letter-spacing: -0.01em;
    text-transform: lowercase;
  }

  .hero-social span { color: var(--hero-faint); }
  .hero-social a:hover { color: var(--hero-fg); }

  .hero-meteors {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    overflow: hidden;
    opacity: 0.7;
  }

  .meteor-lane {
    position: absolute;
    inset: 0;
    left: 50%;
    translate: -50% 0;
    width: 100vw;
    aspect-ratio: 1;
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero-fade {
    opacity: 0;
    animation: fadeUp 0.6s ease-out forwards;
  }

  .hero-delay-1 { animation-delay: 0.08s; }
  .hero-delay-2 { animation-delay: 0.16s; }
  .hero-delay-3 { animation-delay: 0.24s; }
  .hero-delay-4 { animation-delay: 0.32s; }
  .hero-delay-5 { animation-delay: 0.4s; }
  .hero-delay-6 { animation-delay: 0.48s; }


  @keyframes cursorPulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  @keyframes streak {
    0% { translate: 0 200%; opacity: 0; }
    20% { opacity: 1; }
    80% { opacity: 0.5; }
    100% { translate: 0 0; opacity: 0; }
  }

  :global(.streak) {
    position: absolute;
    width: 1px;
    height: 60vh;
    background: linear-gradient(to bottom, var(--hero-fg), transparent 80%);
    opacity: 0;
    animation: streak 2.5s ease-in-out forwards;
  }

  :root :global(.streak) { filter: opacity(0.2); }
  :root[data-theme='dark'] :global(.streak) { filter: none; }

  /* ── Cyberpunk hero effects ────────── */
  :root[data-theme='cyberpunk'] .hero-shell {
    background:
      radial-gradient(ellipse 40% 30% at 30% 20%, rgba(0, 240, 255, 0.04), transparent),
      radial-gradient(ellipse 35% 25% at 70% 70%, rgba(255, 45, 149, 0.03), transparent),
      #06060e;
  }

  :root[data-theme='cyberpunk'] .hero-vignette {
    background:
      linear-gradient(180deg, rgba(6,6,14,0.1) 0%, transparent 20%, transparent 55%, #0a0a14 100%),
      radial-gradient(circle at 50% 14%, transparent 20%, rgba(6,6,14,0.2) 100%);
  }

  :root[data-theme='cyberpunk'] .hero-command {
    color: #00f0ff;
    text-shadow: 0 0 8px rgba(0, 240, 255, 0.3);
  }

  :root[data-theme='cyberpunk'] .hero-name {
    color: #e0e4ff;
    text-shadow: 0 0 30px rgba(0, 240, 255, 0.12), 0 0 60px rgba(0, 240, 255, 0.05);
  }

  :root[data-theme='cyberpunk'] .cursor-blink {
    -webkit-text-fill-color: #00f0ff;
    text-shadow: 0 0 10px rgba(0, 240, 255, 0.6), 0 0 30px rgba(0, 240, 255, 0.2);
    filter: none;
  }

  :root[data-theme='cyberpunk'] .hero-legend span:nth-child(1)::before { background: #00f0ff; box-shadow: 0 0 4px rgba(0, 240, 255, 0.5); }
  :root[data-theme='cyberpunk'] .hero-legend span:nth-child(2)::before { background: #ff2d95; box-shadow: 0 0 4px rgba(255, 45, 149, 0.4); }
  :root[data-theme='cyberpunk'] .hero-legend span:nth-child(3)::before { background: #f0e040; box-shadow: 0 0 4px rgba(240, 224, 64, 0.3); }

  :root[data-theme='cyberpunk'] .hero-social a:hover {
    color: #00f0ff;
    text-shadow: 0 0 6px rgba(0, 240, 255, 0.4);
  }

  :root[data-theme='cyberpunk'] :global(.streak) {
    background: linear-gradient(to bottom, #00f0ff, transparent 80%);
    filter: none;
  }

  @keyframes neonShift {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  @media (max-width: 900px) {
    .hero-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 639px) {
    .hero-shell {
      min-height: 18rem;
      height: min(26rem, 42vh);
    }

    .hero-copy {
      min-height: 12rem;
    }

    .hero-name {
      white-space: normal;
    }
  }
</style>

<script>
  // Stars handled by StarField.tsx (tsParticles)

  const lanes = document.querySelectorAll('.meteor-lane')

  function spawn() {
    if (!lanes.length) return
    const lane = lanes[Math.floor(Math.random() * lanes.length)]
    const el = document.createElement('div')
    el.className = 'streak'
    el.style.left = Math.random() * 100 + '%'
    el.style.top = Math.random() * 50 + '%'
    lane.appendChild(el)
    setTimeout(() => el.remove(), 3000)
  }

  function loop() {
    spawn()
    setTimeout(loop, 1500 + Math.random() * 2000)
  }

  setTimeout(loop, 2000)
</script>
