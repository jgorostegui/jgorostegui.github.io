---
import Link from '@/components/link.astro'
import MobileNav from '@/components/MobileNav'
import SearchButton from '@/components/SearchButton'
import ThemeToggle from '@/components/theme-toggle.astro'
import { FEATURES, NAV_LINKS, SITE } from '@/consts'
import { Image } from 'astro:assets'
import logo from '../../public/static/logo.svg'

// When the mobile nav is enabled, the desktop <nav> collapses below `sm:`
// and the hamburger dropdown takes over. When disabled (safety hatch),
// the desktop nav renders at every width and no hamburger appears.
const mobileNavEnabled = FEATURES.mobileNav.enabled
const searchEnabled = FEATURES.search.enabled

function normalizePath(path: string): string {
  return path.length > 1 ? path.replace(/\/+$/, '') : path
}

const currentPath = normalizePath(Astro.url.pathname)
---

<div>
  <div
    class="mx-auto flex max-w-3xl items-center justify-between gap-4 px-4 py-3"
  >
    <Link href="/" class="flex shrink-0 items-center justify-center gap-3">
      <Image src={logo} alt="Logo" class="size-5 sm:size-6" />
      <span
        class="hidden h-full text-lg leading-none font-medium min-[400px]:block"
        >{SITE.title}</span
      >
    </Link>
    <div class="flex items-center gap-4">
      <nav
        class:list={[
          'items-center gap-4 text-sm sm:gap-6',
          mobileNavEnabled ? 'hidden sm:flex' : 'flex',
        ]}
      >
        {
          NAV_LINKS.map((item) =>
            (() => {
              const targetPath = normalizePath(item.href)
              const isActive =
                targetPath === '/blog'
                  ? currentPath === targetPath ||
                    currentPath.startsWith(`${targetPath}/`)
                  : currentPath === targetPath

              return (
                <Link
                  href={item.href}
                  aria-current={isActive ? 'page' : undefined}
                  class:list={[
                    'header-pill px-2.5 py-1 text-sm capitalize',
                    isActive
                      ? 'header-pill-active text-foreground'
                      : 'text-foreground/60 hover:text-foreground',
                  ]}
                >
                  {item.label}
                </Link>
              )
            })(),
          )
        }
      </nav>
      {searchEnabled && <SearchButton client:idle className="header-pill" />}
      {
        mobileNavEnabled && (
          <MobileNav
            client:idle
            links={NAV_LINKS}
            className="header-pill sm:hidden"
          />
        )
      }
      <ThemeToggle transition:persist />
    </div>
  </div>
</div>
