---
import SchemaMarkup from '@/components/schema-markup.astro'
import { FEATURES, SITE } from '@/consts'
import { isSubpost, parseAuthors } from '@/lib/data-utils'
import { blogPostingSchema } from '@/lib/schema'
import type { CollectionEntry } from 'astro:content'

interface Props {
  post: CollectionEntry<'blog'>
}

const { post } = Astro.props

const title = post.data.title || SITE.title
const description = post.data.description || SITE.description

// Resolve author display names from the authors collection so the OG
// meta and BlogPosting schema show "Josu Gorostegui" rather than the
// slug "josu-gorostegui". Fall back to SITE.author when no author is
// set on the frontmatter.
const resolvedAuthors = await parseAuthors(post.data.authors ?? [])
const authorNames =
  resolvedAuthors.length > 0
    ? resolvedAuthors.map((a) => a.name)
    : [SITE.author]
const author = authorNames.join(', ')

// OG image precedence:
//   1. Dynamic per-post card at /og/<slug>.png (when ENABLE_OG_IMAGES=true)
//      - the primary mechanism; branded title cards render better in feeds
//        than arbitrary cover images.
//   2. Author-supplied cover image - fallback when the dynamic endpoint
//      is disabled or the flag is off.
//   3. null - meta tag is omitted entirely.
const ogImagesEnabled = FEATURES.ogImages.enabled
const coverImage = post?.data?.image?.src
  ? new URL(post.data.image.src, SITE.href)
  : null
const ogImage = ogImagesEnabled
  ? new URL(`/og/${post.id}.png`, Astro.site)
  : coverImage

// BlogPosting JSON-LD. Emitted for every blog post, including subposts -
// Google is fine with structured data on noindexed pages; it's used if
// the noindex is ever lifted.
const blogPosting = blogPostingSchema({
  title,
  description,
  datePublished: post.data.date,
  authors: authorNames,
  imageUrl: ogImage,
  canonicalUrl: Astro.url,
  tags: post.data.tags ?? [],
})
---

<title>{`${title} | ${SITE.title}`}</title>
<meta name="title" content={`${title} | ${SITE.title}`} />
<meta name="description" content={description} />
<link rel="canonical" href={Astro.url} />

{isSubpost(post.id) && <meta name="robots" content="noindex" />}

<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
{ogImage && <meta property="og:image" content={ogImage} />}
{ogImage && <meta property="og:image:alt" content={title} />}
<meta property="og:type" content="article" />
<meta property="og:locale" content={SITE.locale} />
<meta property="og:site_name" content={SITE.title} />
<meta property="og:url" content={Astro.url} />
<meta property="og:author" content={author} />

<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
{ogImage && <meta property="twitter:image" content={ogImage} />}
{ogImage && <meta name="twitter:image:alt" content={title} />}
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:creator" content={author} />

{
  post?.data.tags &&
    post.data.tags.map((tag: string) => {
      return <meta property="article:tag" content={tag} />
    })
}

<SchemaMarkup schema={blogPosting} />
