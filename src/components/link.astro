---
import { cn } from '@/lib/utils'

interface Props {
  href: string
  external?: boolean
  class?: string
  underline?: boolean
  rel?: string
  [key: string]: any
}

const {
  href,
  external,
  class: className,
  underline,
  rel,
  ...rest
} = Astro.props

const relValue = external
  ? Array.from(
      new Set([
        'noopener',
        'noreferrer',
        ...String(rel || '')
          .split(/\s+/)
          .filter(Boolean),
      ]),
    ).join(' ')
  : rel
---

<a
  href={href}
  target={external ? '_blank' : '_self'}
  rel={relValue}
  class={cn(
    'inline-block transition-colors duration-300 ease-in-out',
    underline &&
      'underline decoration-muted-foreground underline-offset-[3px] hover:decoration-foreground',
    className,
  )}
  {...rest}
>
  <slot />
</a>
