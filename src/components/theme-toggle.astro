---
import { Button } from '@/components/ui/button'
import { Icon } from 'astro-icon/components'
---

<Button
  id="theme-toggle"
  variant="ghost"
  size="icon"
  title="Toggle theme"
  className="-my-2 -me-2 size-8"
>
  <Icon name="lucide:sun" class="size-4 theme-icon-light" />
  <Icon name="lucide:moon" class="absolute size-4 theme-icon-dark" />
  <svg class="absolute size-4 theme-icon-cyber" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
  </svg>
  <span class="sr-only">Toggle theme</span>
</Button>

<style>
  .theme-icon-light, .theme-icon-dark, .theme-icon-cyber { display: none; }
  :root[data-theme='light'] .theme-icon-light { display: block; }
  :root[data-theme='dark'] .theme-icon-dark { display: block; }
  :root[data-theme='cyberpunk'] .theme-icon-cyber { display: block; color: #00f0ff; filter: drop-shadow(0 0 4px rgba(0, 240, 255, 0.5)); }
</style>

<script is:inline data-astro-rerun>
  ;(() => {
    const THEMES = ['light', 'dark', 'cyberpunk']
    const theme = (() => {
      const stored = localStorage?.getItem('theme') ?? ''
      if (THEMES.includes(stored)) return stored
      return window.matchMedia('(prefers-color-scheme: dark)').matches
        ? 'dark'
        : 'light'
    })()

    document.documentElement.setAttribute('data-theme', theme)
    window.localStorage.setItem('theme', theme)
  })()
</script>

<script>
  const THEMES = ['light', 'dark', 'cyberpunk']

  function handleToggleClick() {
    const element = document.documentElement
    const currentTheme = element.getAttribute('data-theme') || 'light'
    const idx = THEMES.indexOf(currentTheme)
    const newTheme = THEMES[(idx + 1) % THEMES.length]

    element.classList.add('[&_*]:transition-none')
    element.setAttribute('data-theme', newTheme)
    window.getComputedStyle(element).getPropertyValue('opacity')

    requestAnimationFrame(() => {
      element.classList.remove('[&_*]:transition-none')
    })

    localStorage.setItem('theme', newTheme)
  }

  function initThemeToggle() {
    document
      .getElementById('theme-toggle')
      ?.addEventListener('click', handleToggleClick)
  }

  initThemeToggle()

  document.addEventListener('astro:after-swap', () => {
    const THEMES = ['light', 'dark', 'cyberpunk']
    const storedTheme = localStorage.getItem('theme') || 'light'
    const theme = THEMES.includes(storedTheme) ? storedTheme : 'light'
    const element = document.documentElement

    element.classList.add('[&_*]:transition-none')
    window.getComputedStyle(element).getPropertyValue('opacity')
    element.setAttribute('data-theme', theme)

    requestAnimationFrame(() => {
      element.classList.remove('[&_*]:transition-none')
    })

    initThemeToggle()
  })
</script>
